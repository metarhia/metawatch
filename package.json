{
  "name": "metawatch",
  "version": "2.0.0",
  "author": "Timur Shemsedinov <timur.shemsedinov@gmail.com>",
  "description": "Recursive file and directory watcher for Node.js with debouncing, event deduplication, and zero dependencies.",
  "license": "MIT",
  "keywords": [
    "fs",
    "watch",
    "file-watcher",
    "directory-watcher",
    "recursive",
    "filesystem",
    "inotify",
    "debounce",
    "metarhia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metarhia/metawatch.git"
  },
  "exports": {
    ".": {
      "types": "./metawatch.d.ts",
      "require": "./metawatch.js",
      "default": "./metawatch.js"
    }
  },
  "bugs": {
    "url": "https://github.com/metarhia/metawatch/issues",
    "email": "timur.shemsedinov@gmail.com"
  },
  "homepage": "https://github.com/metarhia/metawatch#readme",
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/tshemsedinov"
  },
  "main": "metawatch.js",
  "types": "metawatch.d.ts",
  "readmeFilename": "README.md",
  "files": [
    "metawatch.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run lint && npm run types && node --test",
    "types": "tsc -p tsconfig.json",
    "lint": "eslint . && prettier -c \"**/*.js\" \"**/*.json\" \"**/*.md\" \"**/*.yml\" \"**/*.ts\"",
    "fix": "eslint . --fix && prettier --write \"**/*.js\" \"**/*.json\" \"**/*.md\" \"**/*.yml\" \"**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "eslint-config-metarhia": "^9.1.8",
    "metaskills": "^1.0.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
